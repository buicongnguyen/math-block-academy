{
  "name": "math-block-academy",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:assets": "node scripts/generate-game-assets.mjs",
    "generate:content": "node scripts/regenerate-content.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "build": "npm run validate:content && tsc && vite build",
    "preview": "vite preview",
    "preview:local": "vite preview --host 127.0.0.1 --port 4173",
    "preview:phone": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "phaser": "^3.80.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
